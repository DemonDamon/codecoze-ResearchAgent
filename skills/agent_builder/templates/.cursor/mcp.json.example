{
    "mcpServers": {
        "my-agent": {
            "command": "/path/to/python",
            "args": ["-m", "src.mcp_server"],
            "cwd": "/path/to/your/project",
            "env": {
                "PYTHONPATH": "/path/to/your/project",
                "OPENAI_API_KEY": "your-api-key-here",
                "OPENAI_BASE_URL": "https://api.openai.com/v1",
                "OPENAI_MODEL": "gpt-4o"
            }
        }
    }
}
