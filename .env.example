# ===========================================
# Coze 平台运行时配置（平台自动注入，本地无需配置）
# ===========================================
# COZE_WORKSPACE_PATH=/workspace/projects
# COZE_WORKLOAD_IDENTITY_API_KEY=xxx
# COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn/v1

# ===========================================
# 本地开发配置（选择一个配置即可）
# ===========================================

# ---------- 方案 A：火山引擎（豆包大模型）----------
# 文档：https://www.volcengine.com/docs/82379/1298454
OPENAI_API_KEY=你的火山引擎API-Key
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_MODEL=doubao-seed-1-8-251228

# ---------- 方案 B：OpenAI ----------
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ---------- 方案 C：DeepSeek ----------
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ---------- 方案 D：Kimi（月之暗面）----------
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=moonshot-v1-8k

# ---------- 方案 E：智谱 AI ----------
# OPENAI_API_KEY=xxxx.xxxx
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_MODEL=glm-4

# ===========================================
# 搜索服务配置（可选，用于本地模式）
# ===========================================

# ---------- Bocha AI 搜索（推荐）----------
# 获取 API Key：https://bocha.io
# 本地模式下使用 Bocha 搜索替代 Coze 搜索服务
BOCHA_API_KEY=sk-xxxx

# ===========================================
# 可选配置
# ===========================================
# 工作目录（默认为当前目录）
# WORKSPACE_PATH=./workspace

# 日志级别
LOG_LEVEL=INFO
